{
  "name": "thragg",
  "owner": {
    "name": "KushTurner",
    "url": "https://github.com/KushTurner"
  },
  "metadata": {
    "description": "Sync shared Claude agent rules and settings into any repo",
    "version": "1.1.0"
  },
  "plugins": [
    {
      "name": "trg",
      "source": "./plugins/trg/",
      "description": "Shared rules, skills, and agents for consistent Claude behaviour across repos",
      "version": "1.1.0",
      "author": {
        "name": "KushTurner",
        "url": "https://github.com/KushTurner"
      },
      "homepage": "https://github.com/KushTurner/thragg",
      "repository": "https://github.com/KushTurner/thragg",
      "keywords": [
        "rules",
        "skills",
        "agents",
        "workflow"
      ],
      "category": "workflows",
      "skills": [
        "./skills/init",
        "./skills/write-tests",
        "./skills/error-handling",
        "./skills/architecture",
        "./skills/create-skill",
        "./skills/ci-pipeline"
      ],
      "agents": [
        "./agents/code-reviewer/AGENT.md",
        "./agents/feature/AGENT.md"
      ],
      "settings": {
        "permissions": {
          "allow": [
            "Bash(git *)",
            "Bash(ls*)",
            "Bash(cat *)",
            "Bash(mkdir *)",
            "Bash(cp *)",
            "Bash(mv *)",
            "Bash(rg *)",
            "Bash(grep *)",
            "Bash(fd *)",
            "Bash(find *)",
            "Bash(jq *)",
            "Bash(head *)",
            "Bash(tail *)",
            "Bash(wc *)",
            "Bash(diff *)",
            "Bash(tree *)",
            "Bash(which *)",
            "Bash(make *)",
            "Bash(docker *)",
            "Bash(docker compose *)",
            "Bash(curl *)",
            "Bash(gh *)",
            "Bash(echo *)",
            "Bash(printf *)",
            "Bash(sort *)",
            "Bash(uniq *)",
            "Bash(cut *)",
            "Bash(tr *)",
            "Bash(sed *)",
            "Bash(awk *)",
            "Bash(xargs *)",
            "Bash(tee *)",
            "Bash(touch *)",
            "Bash(pwd)",
            "Bash(date *)",
            "Bash(stat *)",
            "Bash(basename *)",
            "Bash(dirname *)",
            "Bash(open *)",
            "Bash(ps *)",
            "Bash(env)",
            "Bash(printenv *)"
          ],
          "deny": [
            "Bash(git push --force*)",
            "Bash(git push -f *)",
            "Bash(git push -f)",
            "Bash(git reset --hard*)",
            "Bash(git clean -fd*)",
            "Bash(git branch -D*)",
            "Bash(rm -rf*)",
            "Bash(chmod 777*)",
            "Bash(npm publish*)",
            "Bash(curl *|*)",
            "Bash(curl *-O *)",
            "Bash(curl *--output*)"
          ]
        }
      }
    }
  ]
}
